{
  "name": "@shinederu/auth-core",
  "version": "0.1.0",
  "description": "Framework-agnostic authentication client for Shinederu projects",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
